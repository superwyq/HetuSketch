{
  "extends": "./tsconfig.web.json",
  "compilerOptions": {
    "composite": true,
    "types": ["node", "vite/client", "vitest/globals", "@testing-library/jest-dom"]
  },
  "include": [
    "src/renderer/vite-env.d.ts",
    "src/renderer/src/**/*.ts",
    "src/renderer/src/**/*.tsx",
    "src/renderer/test/**/*.ts",
    "src/shared/**/*.ts",
    "src/main/**/*.ts"
  ]
}
